{
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "generate": {
         "description": "Generate with current prompt",
         "suggested_key": {
            "default": "Alt+G"
         }
      },
      "toggle-sidebar": {
         "description": "Toggle sidebar",
         "suggested_key": {
            "default": "Alt+S"
         }
      }
   },
   "content_scripts": [ {
      "css": [  ],
      "js": [ "content.js" ],
      "matches": [ "https://labs.google/fx/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "slate-bridge.js" ],
      "matches": [ "https://labs.google/fx/*" ],
      "run_at": "document_idle",
      "world": "MAIN"
   }, {
      "js": [ "oauth-bridge.js" ],
      "matches": [ "*://labs.toby.vn/auth/google/success*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "description": "Automate AI generation via API and more",
   "host_permissions": [ "https://labs.google/*", "*://chatgpt.com/*", "*://gemini.google.com/*", "https://grok.com/*", "https://*.grok.com/*", "*://x.com/*", "*://*.x.com/*", "*://labs.toby.vn/*", "*://storage.googleapis.com/*", "*://flow-content.google/*", "*://www.pinterest.com/*", "*://www.youtube.com/*", "*://www.tiktok.com/*", "*://www.google.com/*", "*://www.facebook.com/*", "*://unsplash.com/*", "*://www.etsy.com/*", "*://pixabay.com/*", "*://www.amazon.com/*" ],
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
   },

   "manifest_version": 3,
   "name": "SlncTrZ - Video Maker",
   "permissions": [ "activeTab", "storage", "unlimitedStorage", "sidePanel", "scripting", "tabs", "downloads", "notifications", "alarms" ],
   "short_name": "SlncTrZ-VM",
   "side_panel": {
      "default_path": "sidebar.html"
   },
   "version": "0.0.0",
   "web_accessible_resources": [ {
      "matches": [ "https://labs.google/*" ],
      "resources": [ "sidebar.html", "workflow-editor.html", "workflow-template-editor.html", "workflow-template-editor-init.js", "angles-editor.html", "effects-editor.html", "settings.html", "settings.css", "settings-page.js", "workflow-editor-init.js", "angles-editor-init.js", "effects-editor-init.js", "angles-editor.css", "src/**/*.js", "src/**/*.css", "lib/*.js", "lib/*.css" ]
   } ]
}
